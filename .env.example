# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=live  # not used by code but kept for clarity

# Frontend PayPal SDK (used by CheckoutPage)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
# Optional environment for SDK; set to "sandbox" when testing with a sandbox client ID
# Leaving unset or using any other value will load production (live) JS
VITE_PAYPAL_ENV=sandbox

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
